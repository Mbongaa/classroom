{
  "mcpServers": {
    "shadcn": {
      "command": "cmd.exe",
      "args": ["/c", "npx", "shadcn@latest", "mcp"]
    },
    "supabase": {
      "command": "cmd.exe",
      "args": [
        "/c",
        "npx",
        "-y",
        "@supabase/mcp-server-supabase@latest",
        "--read-only",
        "--project-ref=vmxjczdwyhrierexjoph"
      ],
      "env": {
        "SUPABASE_ACCESS_TOKEN": "${SUPABASE_ACCESS_TOKEN}"
      }
    }
  }
}
